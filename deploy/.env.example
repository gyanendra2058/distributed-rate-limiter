# Production environment variables
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=rate_limiter
NODE_ENV=production

# ── EC2 Deployment ──
# Generated by setup-ec2.sh (do not create manually):
#   deploy/.env.ec2       — instance ID, public IP, key path
#   deploy/rate-limiter-key.pem — SSH key
#
# Required: AWS CLI configured (aws configure)
# Optional: AWS_REGION=us-east-1 (default)
