{
  "family": "rate-limiter-demo",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "2048",
  "memory": "4096",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "redis",
      "image": "redis:7-alpine",
      "essential": true,
      "portMappings": [{ "containerPort": 6379 }],
      "healthCheck": {
        "command": ["CMD", "redis-cli", "ping"],
        "interval": 10,
        "timeout": 5,
        "retries": 3
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/rate-limiter-demo",
          "awslogs-region": "ap-south-1",
          "awslogs-stream-prefix": "redis"
        }
      }
    },
    {
      "name": "postgres",
      "image": "postgres:16-alpine",
      "essential": true,
      "portMappings": [{ "containerPort": 5432 }],
      "environment": [
        { "name": "POSTGRES_USER", "value": "postgres" },
        { "name": "POSTGRES_PASSWORD", "value": "postgres" },
        { "name": "POSTGRES_DB", "value": "rate_limiter" }
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "pg_isready -U postgres"],
        "interval": 10,
        "timeout": 5,
        "retries": 3
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/rate-limiter-demo",
          "awslogs-region": "ap-south-1",
          "awslogs-stream-prefix": "postgres"
        }
      }
    },
    {
      "name": "api",
      "image": "ACCOUNT_ID.dkr.ecr.ap-south-1.amazonaws.com/rate-limiter-api:latest",
      "essential": true,
      "portMappings": [{ "containerPort": 3000 }],
      "environment": [
        { "name": "PORT", "value": "3000" }
      ],
      "dependsOn": [
        { "containerName": "redis", "condition": "HEALTHY" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/rate-limiter-demo",
          "awslogs-region": "ap-south-1",
          "awslogs-stream-prefix": "api"
        }
      }
    },
    {
      "name": "api-gateway",
      "image": "ACCOUNT_ID.dkr.ecr.ap-south-1.amazonaws.com/rate-limiter-gateway:latest",
      "essential": true,
      "portMappings": [{ "containerPort": 5000 }],
      "environment": [
        { "name": "REDIS_HOST", "value": "localhost" },
        { "name": "REDIS_PORT", "value": "6379" },
        { "name": "PORT", "value": "5000" },
        { "name": "API_SERVICE_URL", "value": "http://localhost:3000" }
      ],
      "dependsOn": [
        { "containerName": "redis", "condition": "HEALTHY" },
        { "containerName": "api", "condition": "START" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/rate-limiter-demo",
          "awslogs-region": "ap-south-1",
          "awslogs-stream-prefix": "gateway"
        }
      }
    },
    {
      "name": "config-service",
      "image": "ACCOUNT_ID.dkr.ecr.ap-south-1.amazonaws.com/rate-limiter-config:latest",
      "essential": true,
      "portMappings": [{ "containerPort": 4000 }],
      "environment": [
        { "name": "REDIS_HOST", "value": "localhost" },
        { "name": "REDIS_PORT", "value": "6379" },
        { "name": "PORT", "value": "4000" },
        { "name": "DB_HOST", "value": "localhost" },
        { "name": "DB_PORT", "value": "5432" },
        { "name": "DB_USERNAME", "value": "postgres" },
        { "name": "DB_PASSWORD", "value": "postgres" },
        { "name": "DB_NAME", "value": "rate_limiter" }
      ],
      "dependsOn": [
        { "containerName": "redis", "condition": "HEALTHY" },
        { "containerName": "postgres", "condition": "HEALTHY" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/rate-limiter-demo",
          "awslogs-region": "ap-south-1",
          "awslogs-stream-prefix": "config"
        }
      }
    },
    {
      "name": "dashboard",
      "image": "ACCOUNT_ID.dkr.ecr.ap-south-1.amazonaws.com/rate-limiter-dashboard:latest",
      "essential": true,
      "portMappings": [{ "containerPort": 3001 }],
      "environment": [
        { "name": "PORT", "value": "3001" },
        { "name": "API_GATEWAY_URL", "value": "http://localhost:5000" },
        { "name": "CONFIG_SERVICE_URL", "value": "http://localhost:4000" },
        { "name": "PROMETHEUS_URL", "value": "http://localhost:9090" }
      ],
      "dependsOn": [
        { "containerName": "api-gateway", "condition": "START" },
        { "containerName": "config-service", "condition": "START" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/rate-limiter-demo",
          "awslogs-region": "ap-south-1",
          "awslogs-stream-prefix": "dashboard"
        }
      }
    },
    {
      "name": "prometheus",
      "image": "prom/prometheus:latest",
      "essential": false,
      "portMappings": [{ "containerPort": 9090 }],
      "dependsOn": [
        { "containerName": "api-gateway", "condition": "START" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/rate-limiter-demo",
          "awslogs-region": "ap-south-1",
          "awslogs-stream-prefix": "prometheus"
        }
      }
    }
  ]
}
